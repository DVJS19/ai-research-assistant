# ─── AI Research Assistant — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is in .gitignore.

# ── LLM Providers (at least one required) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...          # optional fallback

# ── Vector DB ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=research-assistant
PINECONE_ENVIRONMENT=us-east-1-aws    # your Pinecone region

# ── Reranker ──────────────────────────────────────────────────────────────────
COHERE_API_KEY=...

# ── Web Search ────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=BSA...           # https://brave.com/search/api/

# ── Database (LangGraph checkpoints) ──────────────────────────────────────────
# Local dev: matches docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_assistant

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Observability ─────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true             # enables LangSmith tracing
LANGCHAIN_API_KEY=ls__...             # https://smith.langchain.com
LANGCHAIN_PROJECT=ai-research-assistant

# ── Agent budget limits (per run) ─────────────────────────────────────────────
AGENT_MAX_STEPS=15
AGENT_MAX_TOKENS=50000
AGENT_MAX_COST_USD=2.00
AGENT_MAX_SECONDS=300

# ── Model selection ───────────────────────────────────────────────────────────
# Workers use the cheap model; synthesis uses the large model
WORKER_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o
FALLBACK_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# ── App config ────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
LOG_LEVEL=INFO
